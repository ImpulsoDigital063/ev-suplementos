generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum StatusAgendamento {
  PENDENTE
  CONFIRMADO
  CANCELADO
  CONCLUIDO
}

enum StatusProtocolo {
  RASCUNHO
  ATIVO
  ARQUIVADO
}

enum CategoriaProtocolo {
  EMAGRECIMENTO
  HIPERTROFIA
  SAUDE_GERAL
  PERFORMANCE
  OUTRO
}

enum StatusMensagem {
  NAO_LIDA
  LIDA
  RESPONDIDA
}

enum TipoInteracao {
  VISUALIZACAO
  CLIQUE
  FORMULARIO
  COMPRA
  OUTRO
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Cliente {
  id           String        @id @default(cuid())
  nome         String
  email        String        @unique
  telefone     String?
  dataNasc     DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  agendamentos Agendamento[]
  depoimentos  Depoimento[]
  mensagens    Mensagem[]
  interacoes   Interacao[]

  @@map("clientes")
}

model Protocolo {
  id                 String             @id @default(cuid())
  nome               String
  slug               String             @unique
  descricao          String
  descricao_curta    String             @default("")
  conteudo           String             @default("")
  resultado_esperado String             @default("")
  tipo               String             @default("IV")
  icone              String             @default("✨")
  keywords           String             @default("[]") // JSON: ["tag1","tag2"]
  clientes_atendidos Int                @default(0)
  preco_min          Float              @default(0)
  preco_max          Float              @default(0)
  frequencia         String             @default("")
  categoria          CategoriaProtocolo @default(OUTRO)
  status             StatusProtocolo    @default(RASCUNHO)
  ativo              Boolean            @default(false)
  duracao            Int?
  destaque           Boolean            @default(false)
  imagemUrl          String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  agendamentos Agendamento[]

  @@map("protocolos")
}

model Agendamento {
  id           String            @id @default(cuid())
  clienteId    String
  protocoloId  String?
  dataHora     DateTime
  status       StatusAgendamento @default(PENDENTE)
  observacoes  String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  cliente      Cliente           @relation(fields: [clienteId], references: [id])
  protocolo    Protocolo?        @relation(fields: [protocoloId], references: [id])

  @@map("agendamentos")
}

model Depoimento {
  id         String   @id @default(cuid())
  clienteId  String
  texto      String
  avaliacao  Int      // 1–5
  aprovado   Boolean  @default(false)
  destaque   Boolean  @default(false)
  imagemUrl  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  cliente    Cliente  @relation(fields: [clienteId], references: [id])

  @@map("depoimentos")
}

model BlogPost {
  id         String   @id @default(cuid())
  titulo     String
  slug       String   @unique
  resumo     String
  conteudo   String
  imagemUrl  String?
  publicado  Boolean  @default(false)
  destaque   Boolean  @default(false)
  tags       String   @default("[]") // JSON serializado: ["tag1","tag2"]
  autorNome  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("blog_posts")
}

model Mensagem {
  id         String         @id @default(cuid())
  clienteId  String?
  nome       String
  email      String
  telefone   String?
  assunto    String
  corpo      String
  status     StatusMensagem @default(NAO_LIDA)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  cliente    Cliente?       @relation(fields: [clienteId], references: [id])

  @@map("mensagens")
}

model Interacao {
  id         String        @id @default(cuid())
  clienteId  String?
  tipo       TipoInteracao @default(VISUALIZACAO)
  pagina     String
  detalhes   String?       // JSON serializado
  userAgent  String?
  ip         String?
  createdAt  DateTime      @default(now())

  cliente    Cliente?      @relation(fields: [clienteId], references: [id])

  @@map("interacoes")
}
